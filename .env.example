# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App (public runtime config)
NEXT_PUBLIC_SITE_NAME=FocusHub
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_FROM_EMAIL=noreply@example.com

# SMTP email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=FocusHub

# Gemini (optional for AI coach)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Admin login (server only)
ADMIN_LOGIN_EMAIL=admin@focushub.com
ADMIN_LOGIN_PASSWORD=Admin@12345
